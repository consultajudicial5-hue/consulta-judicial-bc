# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=30

# PJBC scraper URL
PJBC_BOLETIN_URL=https://www.pjbc.gob.mx/boletin/

# Optional: API key for protected admin endpoints
API_SECRET_KEY=change-me-in-production

# Supabase connection (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: Vercel Cron secret (set automatically by Vercel)
# CRON_SECRET=
