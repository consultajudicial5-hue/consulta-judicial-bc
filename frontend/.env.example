# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (required for payments) ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for Premium subscription (create a recurring price in Stripe)
STRIPE_PRICE_ID=price_...

# ── Resend (optional – email alerts) ─────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=alertas@monitojudicial.bc

# ── App settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://monitojudicial.vercel.app

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=30

# PJBC scraper base URL (the path before /YYYY/my_html/inYYMMDD.htm)
PJBC_BOLETIN_BASE=https://www.pjbc.gob.mx/boletinj

